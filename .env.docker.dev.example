# Copy to .env (or pass with --env-file) when using docker-compose.dev.yml
# Typical flow: Postgres in Docker, NestJS on host (npm run start:dev)

NODE_ENV=development
PORT=3000
DB_TYPE=postgres

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=easb
POSTGRES_PORT=5432

DB_URL=postgres://postgres:password@localhost:5432/easb
DB_URL_POSTGRES=postgres://postgres:password@localhost:5432/easb
DB_URL_MYSQL=mysql://root:rootpassword@localhost:3306/easb

# Optional — when running backend in Docker (--profile backend)
BACKEND_PORT=3001
BACKEND_IMAGE=easb-backend:dev

# MySQL alternative (use --profile mysql instead of postgres)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=easb
MYSQL_USER=easb_user
MYSQL_PASSWORD=easb_password
MYSQL_PORT=3306
