{
  "name": "easb-revamp",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/data_source.ts",
    "migration:create": "npm run typeorm -- migration:create src/migrations/postgres/Migration",
    "migration:generate": "npm run typeorm -- migration:generate src/migrations/postgres/Auto -p",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:show": "npm run typeorm -- migration:show",
    "typeorm:postgres": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/data_source.postgres.ts",
    "migration:postgres:run": "npm run typeorm:postgres -- migration:run",
    "migration:postgres:revert": "npm run typeorm:postgres -- migration:revert",
    "migration:postgres:show": "npm run typeorm:postgres -- migration:show",
    "migration:postgres:create": "npm run typeorm:postgres -- migration:create",
    "migration:postgres:generate": "npm run typeorm:postgres -- migration:generate src/migrations/postgres/Auto -p",
    "typeorm:mysql": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/data_source.mysql.ts",
    "migration:mysql:run": "npm run typeorm:mysql -- migration:run",
    "migration:mysql:revert": "npm run typeorm:mysql -- migration:revert",
    "migration:mysql:show": "npm run typeorm:mysql -- migration:show",
    "migration:mysql:create": "npm run typeorm:mysql -- migration:create",
    "migration:mysql:generate": "npm run typeorm:mysql -- migration:generate src/migrations/mysql/Auto -p",
    "db:test": "ts-node -r tsconfig-paths/register src/scripts/test-db-connection.ts",
    "docker:dev:postgres": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --profile postgres up -d",
    "docker:dev:mysql": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --profile mysql up -d",
    "docker:dev:up": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --profile postgres --profile backend up -d --build",
    "docker:prod:up": "docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.production --profile mysql --profile backend --profile nginx --profile observability up -d",
    "docker:test:up": "docker compose -f docker-compose.yml -f docker-compose.test.yml --env-file .env.docker.test --profile postgres up -d --build",
    "docker:test:down": "docker compose -f docker-compose.yml -f docker-compose.test.yml --profile postgres down -v",
    "docker:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --profile postgres --profile backend down"
  },
  "dependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@types/puppeteer": "^5.4.7",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "helmet": "^8.1.0",
    "joi": "^18.0.1",
    "multer": "^2.0.2",
    "mysql2": "^3.16.2",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "prom-client": "^15.1.3",
    "puppeteer": "^24.32.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.27",
    "typeorm-naming-strategies": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/archiver": "^7.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.6.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
