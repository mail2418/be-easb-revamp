# Copy to .env.docker.test for CI / integration tests
#   docker compose -f docker-compose.yml -f docker-compose.test.yml --env-file .env.docker.test --profile postgres up -d

NODE_ENV=test
PORT=3000
DB_TYPE=postgres
ENV_FILE=.env.docker.test

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=easb_test
POSTGRES_PORT=5433

DB_URL=postgres://postgres:password@localhost:5433/easb_test
DB_URL_POSTGRES=postgres://postgres:password@easb-postgres-test:5432/easb_test

BACKEND_PORT=3001
BACKEND_IMAGE=easb-backend:test

SEED_DEFAULT_PASSWORD=12345678
SUPERADMIN_DEFAULT_PASSWORD=SuperAdminPass123!

# Higher auth limit for parallel smoke + E2E login in test containers
RATE_AUTH_REQ_LIMIT=30
