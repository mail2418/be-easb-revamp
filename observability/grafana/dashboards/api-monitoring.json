{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"easb-backend\"}[5m])",
          "legendFormat": "process CPU",
          "refId": "A"
        },
        {
          "expr": "rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=\"backend\",id=~\"/docker/.*\"}[5m])",
          "legendFormat": "container CPU",
          "refId": "B"
        }
      ],
      "title": "CPU Usage Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"easb-backend\"}",
          "legendFormat": "process RSS",
          "refId": "A"
        },
        {
          "expr": "container_memory_working_set_bytes{container_label_com_docker_compose_service=\"backend\",id=~\"/docker/.*\"}",
          "legendFormat": "container working set",
          "refId": "B"
        }
      ],
      "title": "Memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "targets": [
        {
          "expr": "up{job=\"easb-backend\"}",
          "legendFormat": "up",
          "refId": "A"
        }
      ],
      "title": "Backend Up",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_total{job=\"easb-backend\",route=~\"$route\",status=~\"$status_class\"}[5m]))",
          "legendFormat": "request rate",
          "refId": "A"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "min": 0 },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 7 },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_total{job=\"easb-backend\",status=~\"5..\",route=~\"$route\"}[5m])) / sum(rate(http_server_requests_total{job=\"easb-backend\",route=~\"$route\"}[5m]))",
          "legendFormat": "5xx error rate",
          "refId": "A"
        }
      ],
      "title": "Error Rate (5xx)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 7 },
      "id": 6,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, route) (rate(http_server_request_duration_seconds_bucket{job=\"easb-backend\",route=~\"$route\",status=~\"$status_class\"}[5m])))",
          "legendFormat": "p50 {{route}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_server_request_duration_seconds_bucket{job=\"easb-backend\",route=~\"$route\",status=~\"$status_class\"}[5m])))",
          "legendFormat": "p95 {{route}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, route) (rate(http_server_request_duration_seconds_bucket{job=\"easb-backend\",route=~\"$route\",status=~\"$status_class\"}[5m])))",
          "legendFormat": "p99 {{route}}",
          "refId": "C"
        }
      ],
      "title": "Latency by Route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 7 },
      "id": 7,
      "targets": [
        {
          "expr": "sum by (route) (rate(http_server_requests_total{job=\"easb-backend\",route=~\"$route\",status=~\"$status_class\"}[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Route",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "Bps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "id": 8,
      "targets": [
        {
          "expr": "rate(container_fs_reads_bytes_total{container_label_com_docker_compose_service=\"backend\",id=~\"/docker/.*\"}[5m])",
          "legendFormat": "disk read",
          "refId": "A"
        },
        {
          "expr": "rate(container_fs_writes_bytes_total{container_label_com_docker_compose_service=\"backend\",id=~\"/docker/.*\"}[5m])",
          "legendFormat": "disk write",
          "refId": "B"
        }
      ],
      "title": "Container Disk IO",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "Bps" },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "id": 9,
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{container_label_com_docker_compose_service=\"backend\",id=~\"/docker/.*\"}[5m])",
          "legendFormat": "network in",
          "refId": "A"
        },
        {
          "expr": "rate(container_network_transmit_bytes_total{container_label_com_docker_compose_service=\"backend\",id=~\"/docker/.*\"}[5m])",
          "legendFormat": "network out",
          "refId": "B"
        }
      ],
      "title": "Container Network IO",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 21 },
      "id": 10,
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds{job=\"easb-backend\"}",
          "legendFormat": "event loop lag",
          "refId": "A"
        }
      ],
      "title": "Node.js Event Loop Lag",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 21 },
      "id": 11,
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"easb-backend\"}",
          "legendFormat": "heap used",
          "refId": "A"
        }
      ],
      "title": "Node.js Heap Used",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 28 },
      "id": 12,
      "targets": [
        {
          "queryType": "traceql",
          "query": "{ resource.service.name = \"easb-backend\" && span.http.route =~ \".*$route.*\" }",
          "refId": "A"
        }
      ],
      "title": "Traces by Route",
      "type": "traces"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 28 },
      "id": 13,
      "targets": [
        {
          "expr": "{container=\"easb-backend\"} | json | correlationId=~\"$cid\"",
          "refId": "A"
        }
      ],
      "title": "Backend Logs",
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["easb", "api", "lgtm"],
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(http_server_requests_total{job=\"easb-backend\"}, route)",
        "includeAll": true,
        "multi": true,
        "name": "route",
        "query": { "query": "label_values(http_server_requests_total{job=\"easb-backend\"}, route)", "refId": "Prometheus-route" },
        "refresh": 2,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "includeAll": true,
        "multi": true,
        "name": "status_class",
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "2xx", "value": "2.." },
          { "selected": false, "text": "4xx", "value": "4.." },
          { "selected": false, "text": "5xx", "value": "5.." }
        ],
        "query": "2..,4..,5..",
        "type": "custom"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "correlationId",
        "name": "cid",
        "options": [{ "selected": true, "text": "", "value": "" }],
        "query": "",
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "EASB API Monitoring",
  "uid": "easb-api-monitoring",
  "version": 2
}
