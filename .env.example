# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# DB_TYPE: 'mysql' or 'postgres'
DB_TYPE=mysql

# Primary connection URL (used by the app at runtime)
DB_URL=mysql://root:password@localhost:3306/easb

# Dialect-specific URLs (used by TypeORM CLI / migration scripts)
DB_URL_POSTGRES=postgres://postgres:password@localhost:5432/easb
DB_URL_MYSQL=mysql://root:password@localhost:3306/easb

# ─── MySQL container credentials (docker-compose.mysql.easb.yml) ──────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=easb
MYSQL_USER=easb_user
MYSQL_PASSWORD=easb_password
MYSQL_PORT=3306

# ─── PostgreSQL container credentials (docker-compose.postgres.easb.yml) ──────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=easb
POSTGRES_PORT=5432

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=8h
JWT_REFRESH_TTL=24h

# ─── Object Storage ───────────────────────────────────────────────────────────
UPLOAD_DIR=public/

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Default Passwords ────────────────────────────────────────────────────────
SEED_DEFAULT_PASSWORD=change_me
SUPERADMIN_DEFAULT_PASSWORD=change_me

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_TIME_LIMIT=60000
RATE_REQ_LIMIT=100
RATE_AUTH_TIME_LIMIT=60000
RATE_AUTH_REQ_LIMIT=5

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,X-Correlation-Id
CORS_EXPOSED_HEADERS=X-Correlation-Id
CORS_MAX_AGE=86400

# ─── Observability (OpenTelemetry) ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
OTEL_SERVICE_NAME=easb-backend
OTEL_TRACES_SAMPLER_ARG=1.0
# OTEL_ENABLED=false
