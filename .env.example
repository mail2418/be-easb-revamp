NODE_ENV=development
PORT=3000

DB_TYPE=mysql
DB_URL=postgres://postgres:123@localhost:5432/easb
DB_URL_POSTGRES=postgres://postgres:123@localhost:5432/easb
DB_URL_MYSQL=mysql://root@localhost:3306/easb

# JWT
JWT_ACCESS_SECRET=xxx
JWT_REFRESH_SECRET=xxxx
JWT_ACCESS_TTL=8h
JWT_REFRESH_TTL=24h

# Object Storage
UPLOAD_DIR=public/

# Logging
LOG_LEVEL=info

# Pass
SEED_DEFAULT_PASSWORD=123
SUPERADMIN_DEFAULT_PASSWORD=123

# Limiter
RATE_TIME_LIMIT=60000
RATE_REQ_LIMIT=100
RATE_AUTH_TIME_LIMIT=60000
RATE_AUTH_REQ_LIMIT=5

# CORS Configuration
CORS_ORIGINS=http://localhost:3000

# Optional: Customize CORS settings
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,X-Correlation-Id
CORS_EXPOSED_HEADERS=X-Correlation-Id
CORS_MAX_AGE=86400