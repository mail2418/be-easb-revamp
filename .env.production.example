# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
ENV_FILE=.env.production

# ─── Database ─────────────────────────────────────────────────────────────────
# DB_TYPE: 'mysql' or 'postgres'
DB_TYPE=postgres

# Primary connection URL (used by the app at runtime).
# Point to the Docker container name as the host.
#   MySQL:    mysql://<user>:<password>@easb-mysql:3306/<db>
#   Postgres: postgres://<user>:<password>@easb-postgres:5432/<db>
# URL-encode special characters in passwords (e.g. @ → %40).
# Must match POSTGRES_PASSWORD on the existing easb-postgres container.
DB_URL=postgres://postgres:your_url_encoded_password@easb-postgres:5432/easb

# Dialect-specific URLs (used by TypeORM CLI / migration scripts)
DB_URL_POSTGRES=postgres://postgres:your_url_encoded_password@easb-postgres:5432/easb
DB_URL_MYSQL=mysql://easb_user:easb_password@easb-mysql:3306/easb

# ─── MySQL container credentials (docker-compose.mysql.easb.yml) ──────────────
MYSQL_ROOT_PASSWORD=strong_root_password
MYSQL_DATABASE=easb
MYSQL_USER=easb_user
MYSQL_PASSWORD=strong_easb_password
MYSQL_PORT=3306

# ─── PostgreSQL container credentials (docker-compose.postgres.easb.yml) ──────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=strong_postgres_password
POSTGRES_DB=easb
POSTGRES_PORT=5432

# ─── Backend Docker image (docker-compose.backend.easb.yml) ───────────────────
# Set by CI/CD automatically. Override here if deploying manually.
BACKEND_IMAGE=ghcr.io/<your-github-org>/<your-repo>:dev

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_ACCESS_TTL=8h
JWT_REFRESH_TTL=24h

# ─── Object Storage ───────────────────────────────────────────────────────────
UPLOAD_DIR=public/

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=warn

# ─── Default Passwords ────────────────────────────────────────────────────────
SEED_DEFAULT_PASSWORD=change_me_in_production
SUPERADMIN_DEFAULT_PASSWORD=change_me_in_production

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_TIME_LIMIT=60000
RATE_REQ_LIMIT=100
RATE_AUTH_TIME_LIMIT=60000
RATE_AUTH_REQ_LIMIT=5

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set to your actual frontend domain(s), comma-separated
# Include the public API origin if the browser calls the VPS directly.
CORS_ORIGINS=https://your-vercel-app.vercel.app,http://168.110.202.68
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,X-Correlation-Id
CORS_EXPOSED_HEADERS=X-Correlation-Id
CORS_MAX_AGE=86400

# ─── Docker (VPS — avoid clashing with other stacks on shared host) ───────────
# Distinct from legacy easb-backend used by other projects on the same VPS.
BACKEND_CONTAINER_NAME=be-easb-revamp-backend

# ─── Observability (OpenTelemetry) ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
OTEL_SERVICE_NAME=be-easb-revamp-backend
OTEL_TRACES_SAMPLER_ARG=0.1

